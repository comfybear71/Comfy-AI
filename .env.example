# ── Ollama (local LLM server) ────────────────────────────────────────────────
# Your Ollama server URL (DigitalOcean droplet via Caddy reverse proxy)
OLLAMA_API_URL=http://170.64.174.56

# Basic auth password for Caddy (username is always "admin")
OLLAMA_API_KEY=comfyai-2026

# ── Anthropic (Claude models) ────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
# Enables: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── xAI (Grok models) ───────────────────────────────────────────────────────
# Get yours at https://console.x.ai/
# Enables: grok-3, grok-3-mini, grok-2-vision-1212
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT — needs repo read + pull request write permissions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub webhook secret (set when creating webhook on GitHub)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname

# !! Run this migration once after adding the settings column:
# psql $DATABASE_URL -f drizzle/0001_add_settings_column.sql
# Or: npx drizzle-kit push

# ── System prompt ────────────────────────────────────────────────────────────
# Prepended as system message to every chat.
# See docs/PROMPTS.md for examples. Or use /docs in chat to load project docs.
SYSTEM_PROMPT=
